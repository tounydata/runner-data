# Copie vers .env et remplis les valeurs
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
EXPO_PUBLIC_STRAVA_CLIENT_ID=<your-strava-client-id>
# Nom de la Edge Function Supabase pour l'OAuth Strava
EXPO_PUBLIC_STRAVA_OAUTH_FUNCTION=strava-oauth
# Authtoken ngrok requis pour le mode tunnel (https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=<your-ngrok-authtoken>
