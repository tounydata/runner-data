{
  "name": "Vorcelab",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install && curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -o /tmp/cloudflared && sudo install /tmp/cloudflared /usr/local/bin/cloudflared",
  "forwardPorts": [8081, 19000, 19001],
  "portsAttributes": {
    "8081": {
      "label": "Expo Metro",
      "onAutoForward": "silent"
    },
    "19000": {
      "label": "Expo",
      "onAutoForward": "silent"
    },
    "19001": {
      "label": "Expo DevTools",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  }
}
